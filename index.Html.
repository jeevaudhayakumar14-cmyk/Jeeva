<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>College Feedback Form</title>
  <style>
    body{
      margin:0;
      font-family:Arial,sans-serif;
      background:#b71c1c;
      display:flex;
      justify-content:center;
      align-items:center;
      height:100vh;
    }

    .box{
      background:#fff;
      width:360px;
      padding:30px;
      border-radius:10px;
      text-align:center;
      box-shadow:0 0 15px rgba(0,0,0,.3);
    }

    img{
      width:90px;
      margin-bottom:10px;
    }

    input, textarea{
      width:100%;
      padding:12px;
      margin:10px 0;
      border:1px solid #ccc;
      border-radius:5px;
      box-sizing:border-box;
    }

    button{
      width:100%;
      padding:12px;
      background:#b71c1c;
      color:white;
      border:none;
      border-radius:5px;
      cursor:pointer;
    }
  </style>
</head>
<body>

<div class="box">
  <img src="logo.png" alt="College Logo">
  <h2>College Feedback</h2>

  <form action="https://formspree.io/f/xpqgonbr" method="POST">
      <input type="text" name="name" placeholder="Your Name" required>
      <textarea name="feedback" placeholder="Your Feedback" required></textarea>
      <button type="submit">Submit</button>
  </form>
</div>

</body>
</html>
